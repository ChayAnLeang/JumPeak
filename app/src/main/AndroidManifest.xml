<?xml version="1.0" encoding="utf-8"?>
<manifest
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission
        android:maxSdkVersion="28"
        android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

    <application
        tools:targetApi="31"
        android:name=".JumPeakApp"
        android:allowBackup="true"
        android:supportsRtl="true"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:theme="@style/Theme.JumPeak"
        android:fullBackupContent="@xml/backup_rules"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:dataExtractionRules="@xml/data_extraction_rules">
        <activity
            android:exported="false"
            android:name=".presentation.ui.transaction.activity.EditTransactionActivity" />
        <activity
            android:exported="false"
            android:name=".presentation.ui.transaction.activity.AddTransactionActivity" />
        <activity
            android:exported="false"
            android:name=".presentation.ui.ThemeActivity" />
        <activity
            android:exported="false"
            android:name=".presentation.ui.LanguageActivity" />
        <activity
            android:exported="false"
            android:name=".presentation.ui.reminder.activity.ManageReminderActivity" />
        <activity
            android:exported="false"
            android:name=".presentation.ui.reminder.activity.ReminderActivity" />
        <activity
            android:exported="false"
            android:name=".presentation.ui.parties.activity.EditPartiesActivity" />
        <activity
            android:exported="false"
            android:name=".presentation.ui.parties.activity.AddPartiesActivity" />
        <activity
            android:exported="false"
            android:name=".presentation.ui.BaseActivity" />
        <activity
            android:exported="false"
            android:name=".presentation.ui.transaction.activity.TransactionActivity" />
        <activity
            android:exported="true"
            android:name=".presentation.ui.parties.activity.PartiesActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>