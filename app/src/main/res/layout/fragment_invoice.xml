<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white_black"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android"
    tools:context=".presentation.ui.invoice.fragment.InvoiceFragment">

    <LinearLayout
        android:gravity="center"
        android:paddingEnd="12dp"
        android:id="@+id/llDaily"
        android:paddingStart="15dp"
        android:layout_height="55dp"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:id="@+id/icPrevious"
            android:src="@drawable/ic_arrow_back_ios"/>

        <TextView
            android:textSize="18sp"
            android:gravity="center"
            android:id="@+id/tvDate"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/black_white"/>

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/icNext"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:src="@drawable/ic_arrow_forward_ios"/>
    </LinearLayout>

    <View
        android:id="@+id/dvd"
        android:layout_height="1dp"
        android:layout_width="match_parent"
        android:background="@color/black_white"
        app:layout_constraintTop_toBottomOf="@id/llDaily"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv"
        android:visibility="gone"
        android:layout_height="0dp"
        android:layout_width="match_parent"
        app:layout_constraintTop_toBottomOf="@id/dvd"
        app:layout_constraintBottom_toTopOf="@id/llAction"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>

    <ProgressBar
        android:id="@+id/pb"
        android:layout_height="50dp"
        android:layout_gravity="center"
        android:layout_width="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        android:indeterminateTint="@color/black_white"
        app:layout_constraintBottom_toBottomOf="parent" />

    <androidx.appcompat.widget.AppCompatImageView
        android:visibility="gone"
        android:id="@+id/icReceipt"
        android:layout_height="45dp"
        android:layout_width="match_parent"
        android:src="@drawable/ic_receipt_long"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <TextView
        android:textSize="15sp"
        android:gravity="center"
        android:visibility="gone"
        android:id="@+id/tvNoData"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/black_white"
        android:text="@string/no_data_available"
        app:layout_constraintTop_toBottomOf="@id/icReceipt"/>

    <LinearLayout
        android:id="@+id/llAction"
        android:layout_margin="15dp"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:layout_weight="1"
            android:layout_width="0dp"
            app:icon="@drawable/ic_add"
            app:iconGravity="textStart"
            android:layout_height="40dp"
            android:id="@+id/btAddInvoice"
            android:layout_marginEnd="15dp"
            app:iconTint="@color/white_black"
            android:text="@string/add_invoice"
            android:textColor="@color/white_black"
            android:backgroundTint="@color/black_white"/>

        <com.google.android.material.button.MaterialButton
            android:layout_weight="1"
            android:layout_width="0dp"
            android:id="@+id/btUnpaid"
            app:iconGravity="textStart"
            android:layout_height="40dp"
            app:iconTint="@color/white_black"
            app:icon="@drawable/ic_receipt_long"
            android:textColor="@color/white_black"
            android:backgroundTint="@color/black_white"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>