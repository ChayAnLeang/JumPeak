<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/invoiceItem"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <TextView
        android:textSize="15sp"
        android:layout_width="0dp"
        android:layout_margin="10dp"
        android:id="@+id/tvInvoiceNo"
        android:layout_height="wrap_content"
        android:textColor="@color/black_white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/llSummary"/>

    <TextView
        android:textSize="15sp"
        android:id="@+id/tvDate"
        android:layout_width="0dp"
        android:layout_marginTop="3dp"
        android:layout_marginEnd="10dp"
        android:layout_height="wrap_content"
        android:textColor="@color/black_white"
        app:layout_constraintEnd_toStartOf="@id/llSummary"
        app:layout_constraintTop_toBottomOf="@id/tvInvoiceNo"
        app:layout_constraintStart_toStartOf="@id/tvInvoiceNo"/>

    <TextView
        android:textSize="15sp"
        android:layout_width="0dp"
        android:layout_marginTop="3dp"
        android:layout_marginEnd="10dp"
        android:id="@+id/tvCustomerName"
        android:layout_height="wrap_content"
        android:textColor="@color/black_white"
        app:layout_constraintTop_toBottomOf="@id/tvDate"
        app:layout_constraintEnd_toStartOf="@id/llSummary"
        app:layout_constraintStart_toStartOf="@id/tvInvoiceNo"/>

    <TextView
        android:textSize="15sp"
        android:layout_width="0dp"
        android:layout_marginTop="3dp"
        android:layout_marginEnd="10dp"
        android:id="@+id/tvPhoneNumber"
        android:layout_height="wrap_content"
        android:textColor="@color/black_white"
        app:layout_constraintEnd_toStartOf="@id/llSummary"
        app:layout_constraintTop_toBottomOf="@id/tvCustomerName"
        app:layout_constraintStart_toStartOf="@id/tvCustomerName" />

    <LinearLayout
        android:gravity="end"
        android:id="@+id/llSummary"
        android:orientation="vertical"
        android:layout_marginEnd="15dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/icArrow">

        <TextView
            android:textSize="15sp"
            android:id="@+id/tvTotalDue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/black_white"/>

        <TextView
            android:textSize="15sp"
            android:id="@+id/tvTotalPaid"
            android:layout_marginVertical="3dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/black_white"/>

        <TextView
            android:textSize="15sp"
            android:textStyle="bold"
            android:id="@+id/tvBalance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/black_white"/>

        <TextView
            android:textSize="15sp"
            android:id="@+id/tvPaidType"
            android:layout_marginTop="3dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/black_white"/>
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/icArrow"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:src="@drawable/ic_arrow_forward_ios"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <View
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:layout_width="match_parent"
        android:background="@color/black_white"
        app:layout_constraintTop_toBottomOf="@id/tvPhoneNumber"/>
</androidx.constraintlayout.widget.ConstraintLayout>