<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gains_boro_or_dark"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android"
    tools:context=".presentation.ui.transaction.activity.TransactionActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/mtb"
        android:paddingTop="30dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:menu="@menu/transaction_toolbar_menu"
        app:layout_constraintTop_toTopOf="parent"
        app:titleTextColor="@color/black_or_white"
        android:background="@color/white_or_black"
        app:navigationIcon="@drawable/ic_arrow_back"/>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tl"
        android:layout_marginTop="1dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:tabTextColor="@color/black_or_white"
        android:background="@color/white_or_black"
        app:tabIndicatorColor="@color/black_or_white"
        app:layout_constraintTop_toBottomOf="@id/mtb">

        <com.google.android.material.tabs.TabItem
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/unsettled_debt"/>

        <com.google.android.material.tabs.TabItem
            android:text="@string/settled_debt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </com.google.android.material.tabs.TabLayout>

    <LinearLayout
        android:id="@+id/summary"
        android:paddingVertical="5dp"
        android:baselineAligned="false"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white_or_black"
        app:layout_constraintTop_toBottomOf="@id/tl">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content">

            <TextView
                android:textSize="15sp"
                android:gravity="center"
                android:id="@+id/totalDebt"
                android:text="@string/total_debt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/black_or_white"
                app:layout_constraintTop_toTopOf="parent"/>

            <TextView
                android:textSize="15sp"
                android:gravity="center"
                android:id="@+id/tvTotalDebt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/black_or_white"
                app:layout_constraintTop_toBottomOf="@id/totalDebt"/>

            <ProgressBar
                android:layout_height="16dp"
                android:id="@+id/pbTotalDebt"
                android:layout_width="match_parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:indeterminateTint="@color/black_or_white"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content">

            <TextView
                android:textSize="15sp"
                android:gravity="center"
                android:id="@+id/totalRepayment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/total_repayment"
                android:textColor="@color/black_or_white"
                app:layout_constraintTop_toTopOf="parent"/>

            <TextView
                android:textSize="15sp"
                android:gravity="center"
                android:id="@+id/tvTotalRepayment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/black_or_white"
                app:layout_constraintTop_toBottomOf="@id/totalRepayment"/>

            <ProgressBar
                android:layout_height="16dp"
                android:id="@+id/pbTotalRepayment"
                android:layout_width="match_parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:indeterminateTint="@color/black_or_white"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content">

            <TextView
                android:textSize="15sp"
                android:gravity="center"
                android:id="@+id/balance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/outstanding_debt"
                android:textColor="@color/black_or_white"
                app:layout_constraintTop_toTopOf="parent"/>

            <TextView
                android:textSize="15sp"
                android:gravity="center"
                android:id="@+id/tvBalance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/black_or_white"
                app:layout_constraintTop_toBottomOf="@id/balance"/>

            <ProgressBar
                android:id="@+id/pbBalance"
                android:layout_height="16dp"
                android:layout_width="match_parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:indeterminateTint="@color/black_or_white"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/col"
        android:paddingVertical="10dp"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/summary">

        <TextView
            android:textSize="15sp"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_marginStart="5dp"
            android:text="@string/date_and_time"
            android:layout_height="wrap_content"
            android:textColor="@color/black_or_white"/>

        <TextView
            android:textSize="15sp"
            android:layout_width="0dp"
            android:layout_weight="0.5"
            android:text="@string/repayment"
            android:layout_height="wrap_content"
            android:textColor="@color/black_or_white"/>

        <TextView
            android:textSize="15sp"
            android:gravity="center"
            android:layout_width="0dp"
            android:text="@string/debt"
            android:layout_weight="0.5"
            android:layout_height="wrap_content"
            android:textColor="@color/black_or_white"/>
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/icList"
        android:visibility="gone"
        android:layout_height="50dp"
        android:layout_width="match_parent"
        android:src="@drawable/ic_list_alt"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <TextView
        android:textSize="15sp"
        android:gravity="center"
        android:visibility="gone"
        android:id="@+id/tvNoData"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/no_data_available"
        android:textColor="@color/black_or_white"
        app:layout_constraintTop_toBottomOf="@id/icList"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv"
        android:visibility="gone"
        android:layout_height="0dp"
        android:layout_width="match_parent"
        app:layout_constraintTop_toBottomOf="@id/col"
        app:layout_constraintBottom_toTopOf="@id/tvAddDebt"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>

    <ProgressBar
        android:id="@+id/pb"
        android:layout_height="50dp"
        android:layout_width="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:indeterminateTint="@color/black_or_white"/>

    <TextView
        android:textSize="16sp"
        android:gravity="center"
        android:layout_width="0dp"
        android:id="@+id/tvAddDebt"
        android:layout_height="45dp"
        android:text="@string/add_debt"
        android:background="@color/red"
        android:textColor="@color/white"
        app:layout_constraintWidth_percent="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <TextView
        android:textSize="16sp"
        android:gravity="center"
        android:layout_width="0dp"
        android:layout_height="45dp"
        android:textColor="@color/white"
        android:id="@+id/tvAddRepayment"
        android:background="@color/green"
        android:text="@string/add_repayment"
        app:layout_constraintWidth_percent="0.5"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>