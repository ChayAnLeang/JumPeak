<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white_black"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android"
    tools:context=".presentation.ui.invoice.activity.ManageInvoiceActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/mtb"
        android:paddingTop="40dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:titleTextColor="@color/black_white"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_arrow_back" />

    <View
        android:id="@+id/dvd1"
        android:layout_height="1dp"
        android:layout_width="match_parent"
        android:background="@color/black_white"
        app:layout_constraintTop_toBottomOf="@id/mtb"/>

    <LinearLayout
        android:id="@+id/div"
        android:padding="15dp"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/dvd1">

        <RadioGroup
            android:id="@+id/rgCurrency"
            android:layout_height="30dp"
            android:orientation="horizontal"
            android:layout_width="match_parent">

            <com.google.android.material.radiobutton.MaterialRadioButton
                android:checked="true"
                android:id="@+id/rbKHR"
                android:textSize="15sp"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:text="@string/khr"
                app:buttonTint="@color/black_white"
                android:layout_height="wrap_content" />

            <com.google.android.material.radiobutton.MaterialRadioButton
                android:id="@+id/rbUSD"
                android:textSize="15sp"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:text="@string/usd"
                app:buttonTint="@color/black_white"
                android:layout_height="wrap_content" />
        </RadioGroup>

        <LinearLayout
            android:gravity="bottom"
            android:layout_marginTop="10dp"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_weight="1"
                android:layout_width="0dp"
                android:orientation="vertical"
                android:layout_marginEnd="15dp"
                android:layout_height="wrap_content">

                <TextView
                    android:textSize="15sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black_white"
                    android:text="@string/customer_required"/>

                <com.google.android.material.textfield.TextInputEditText
                    android:textSize="15sp"
                    android:clickable="false"
                    android:focusable="false"
                    android:id="@+id/etCustomer"
                    android:layout_height="30dp"
                    android:layout_marginTop="5dp"
                    android:paddingHorizontal="10dp"
                    android:layout_width="match_parent"
                    android:background="@drawable/bg_radius_5_stroke_2"/>
            </LinearLayout>

            <LinearLayout
                android:layout_weight="1"
                android:layout_width="0dp"
                android:orientation="vertical"
                android:layout_height="wrap_content">

                <TextView
                    android:textSize="15sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/goods_required"
                    android:textColor="@color/black_white" />

                <com.google.android.material.textfield.TextInputEditText
                    android:textSize="15sp"
                    android:inputType="text"
                    android:id="@+id/etGoods"
                    android:layout_height="30dp"
                    android:layout_marginTop="5dp"
                    android:paddingHorizontal="10dp"
                    android:layout_width="match_parent"
                    android:textCursorDrawable="@drawable/cursor_color"
                    android:background="@drawable/bg_radius_5_stroke_2"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:gravity="bottom"
            android:layout_marginTop="15dp"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="0.3"
                android:orientation="vertical"
                android:layout_height="wrap_content">

                <TextView
                    android:textSize="15sp"
                    android:text="@string/qty_required"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black_white" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etQty"
                    android:textSize="15sp"
                    android:inputType="number"
                    android:layout_height="30dp"
                    android:layout_marginTop="5dp"
                    android:paddingHorizontal="10dp"
                    android:layout_width="match_parent"
                    android:textCursorDrawable="@drawable/cursor_color"
                    android:background="@drawable/bg_radius_5_stroke_2"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="0.4"
                android:orientation="vertical"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="15dp">

                <TextView
                    android:textSize="15sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/unit_required"
                    android:textColor="@color/black_white" />

                <com.google.android.material.textfield.TextInputEditText
                    android:textSize="15sp"
                    android:id="@+id/etUnit"
                    android:inputType="text"
                    android:layout_height="30dp"
                    android:layout_marginTop="5dp"
                    android:paddingHorizontal="10dp"
                    android:layout_width="match_parent"
                    android:textCursorDrawable="@drawable/cursor_color"
                    android:background="@drawable/bg_radius_5_stroke_2"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="0.5"
                android:orientation="vertical"
                android:layout_marginEnd="15dp"
                android:layout_height="wrap_content">

                <TextView
                    android:textSize="15sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black_white"
                    android:text="@string/unit_price_required" />

                <com.google.android.material.textfield.TextInputEditText
                    android:textSize="15sp"
                    android:id="@+id/etPrice"
                    android:layout_height="30dp"
                    android:layout_marginTop="5dp"
                    android:paddingHorizontal="10dp"
                    android:inputType="numberDecimal"
                    android:layout_width="match_parent"
                    android:textCursorDrawable="@drawable/cursor_color"
                    android:background="@drawable/bg_radius_5_stroke_2"/>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:alpha="0.5"
                android:enabled="false"
                android:id="@+id/btAdd"
                android:layout_width="0dp"
                android:text="@string/add"
                android:layout_weight="0.7"
                app:iconGravity="textStart"
                app:icon="@drawable/ic_add"
                android:layout_height="40dp"
                app:iconTint="@color/white_black"
                android:textColor="@color/white_black"
                android:backgroundTint="@color/black_white"/>
        </LinearLayout>

        <LinearLayout
            android:layout_marginTop="15dp"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_weight="1"
                android:layout_width="0dp"
                android:orientation="vertical"
                android:layout_height="wrap_content">

                <TextView
                    android:textSize="15sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/date_required"
                    android:textColor="@color/black_white" />

                <com.google.android.material.textfield.TextInputEditText
                    android:textSize="15sp"
                    android:id="@+id/etDate"
                    android:clickable="false"
                    android:focusable="false"
                    android:layout_height="30dp"
                    android:layout_marginTop="5dp"
                    android:paddingHorizontal="10dp"
                    android:layout_width="match_parent"
                    android:background="@drawable/bg_radius_5_stroke_2"/>
            </LinearLayout>

            <LinearLayout
                android:layout_weight="1"
                android:layout_width="0dp"
                android:orientation="vertical"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="15dp">

                <TextView
                    android:textSize="15sp"
                    android:text="@string/discount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black_white" />

                <com.google.android.material.textfield.TextInputEditText
                    android:textSize="15sp"
                    android:inputType="number"
                    android:id="@+id/etDiscount"
                    android:layout_height="30dp"
                    android:layout_marginTop="5dp"
                    android:paddingHorizontal="10dp"
                    android:layout_width="match_parent"
                    android:textCursorDrawable="@drawable/cursor_color"
                    android:background="@drawable/bg_radius_5_stroke_2"/>
            </LinearLayout>

            <LinearLayout
                android:layout_weight="1"
                android:layout_width="0dp"
                android:orientation="vertical"
                android:layout_height="wrap_content">

                <TextView
                    android:textSize="15sp"
                    android:text="@string/delivery_fee"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black_white" />

                <com.google.android.material.textfield.TextInputEditText
                    android:textSize="15sp"
                    android:layout_height="30dp"
                    android:layout_marginTop="5dp"
                    android:id="@+id/etDeliveryFee"
                    android:paddingHorizontal="10dp"
                    android:inputType="numberDecimal"
                    android:layout_width="match_parent"
                    android:textCursorDrawable="@drawable/cursor_color"
                    android:background="@drawable/bg_radius_5_stroke_2"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <View
        android:id="@+id/dvd2"
        android:layout_height="1dp"
        android:layout_width="match_parent"
        android:background="@color/black_white"
        app:layout_constraintTop_toBottomOf="@id/div"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv"
        android:visibility="gone"
        android:layout_height="0dp"
        android:layout_width="match_parent"
        app:layout_constraintTop_toBottomOf="@id/dvd2"
        app:layout_constraintBottom_toTopOf="@id/btDone"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>

    <com.google.android.material.button.MaterialButton
        android:alpha="0.5"
        android:enabled="false"
        android:id="@+id/btDone"
        android:text="@string/done"
        app:iconGravity="textStart"
        android:layout_height="40dp"
        android:layout_margin="15dp"
        app:icon="@drawable/ic_done"
        app:iconTint="@color/white_black"
        android:layout_width="match_parent"
        android:textColor="@color/white_black"
        android:backgroundTint="@color/black_white"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <ProgressBar
        android:id="@+id/pb"
        android:visibility="gone"
        android:layout_height="50dp"
        android:layout_width="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        android:indeterminateTint="@color/black_white"
        app:layout_constraintBottom_toBottomOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>