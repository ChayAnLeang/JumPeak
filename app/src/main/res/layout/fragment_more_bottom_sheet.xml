<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/div"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/gains_boro_or_dark"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".presentation.ui.MoreBottomSheetFragment"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <TextView
        android:padding="12dp"
        android:textSize="15sp"
        android:id="@+id/tvLanguage"
        android:drawablePadding="10dp"
        android:gravity="center|start"
        android:text="@string/language"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        android:textColor="@color/black_or_white"
        android:background="@color/white_or_black"
        app:drawableStartCompat="@drawable/ic_language"
        app:drawableEndCompat="@drawable/ic_arrow_forward_ios" />

    <TextView
        android:padding="12dp"
        android:textSize="15sp"
        android:id="@+id/tvTheme"
        android:text="@string/theme"
        android:layout_marginTop="1dp"
        android:drawablePadding="10dp"
        android:gravity="center|start"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/black_or_white"
        android:background="@color/white_or_black"
        app:drawableStartCompat="@drawable/ic_brightness"
        app:layout_constraintTop_toBottomOf="@id/tvLanguage"
        app:drawableEndCompat="@drawable/ic_arrow_forward_ios" />

    <TextView
        android:padding="12dp"
        android:textSize="15sp"
        android:layout_marginTop="1dp"
        android:drawablePadding="10dp"
        android:gravity="center|start"
        android:id="@+id/tvExportOweMe"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/black_or_white"
        android:background="@color/white_or_black"
        app:layout_constraintTop_toBottomOf="@id/tvTheme"
        app:drawableStartCompat="@drawable/ic_playlist_add"
        android:text="@string/export_people_who_owe_me_to_excel"/>

    <TextView
        android:padding="12dp"
        android:textSize="15sp"
        android:layout_marginTop="1dp"
        android:drawablePadding="10dp"
        android:gravity="center|start"
        android:id="@+id/tvExportIOwe"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/black_or_white"
        android:background="@color/white_or_black"
        app:drawableStartCompat="@drawable/ic_playlist_add"
        android:text="@string/export_people_i_owe_to_excel"
        app:layout_constraintTop_toBottomOf="@id/tvExportOweMe"/>

    <ProgressBar
        android:id="@+id/pb"
        android:visibility="gone"
        android:layout_height="40dp"
        android:layout_width="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:indeterminateTint="@color/black_or_white"/>
</androidx.constraintlayout.widget.ConstraintLayout>