<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gains_boro_or_dark"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android"
    tools:context=".presentation.ui.reminder.activity.ManageReminderActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/mtb"
        android:paddingTop="30dp"
        app:titleMarginTop="15dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:titleTextColor="@color/black_or_white"
        android:background="@color/white_or_black"
        app:navigationIcon="@drawable/ic_arrow_back" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/div"
        android:padding="12dp"
        android:layout_marginTop="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white_or_black"
        app:layout_constraintTop_toBottomOf="@id/mtb">

        <TextView
            android:textSize="15sp"
            android:id="@+id/tvMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/message_required"
            android:textColor="@color/black_or_white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/tietMessage"
            app:layout_constraintBottom_toBottomOf="@id/tietMessage"/>

        <com.google.android.material.textfield.TextInputEditText
            android:textSize="15sp"
            android:inputType="text"
            android:layout_width="0dp"
            android:id="@+id/tietMessage"
            android:layout_marginStart="5dp"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:backgroundTint="@color/black_or_white"
            app:layout_constraintStart_toEndOf="@id/tvMessage"
            android:textCursorDrawable="@drawable/cursor_color" />

        <TextView
            android:textSize="15sp"
            android:id="@+id/tvDateTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/black_or_white"
            android:text="@string/date_time_required"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/tietDateTime"
            app:layout_constraintBottom_toBottomOf="@id/tietDateTime"/>

        <com.google.android.material.textfield.TextInputEditText
            android:textSize="15sp"
            android:clickable="false"
            android:focusable="false"
            android:layout_width="0dp"
            android:id="@+id/tietDateTime"
            android:layout_marginStart="5dp"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            android:backgroundTint="@color/black_or_white"
            app:layout_constraintStart_toEndOf="@id/tvDateTime"
            app:layout_constraintTop_toBottomOf="@id/tietMessage"/>

        <LinearLayout
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/tietDateTime">

            <com.google.android.material.button.MaterialButton
                android:alpha="0.5"
                app:cornerRadius="5dp"
                android:enabled="false"
                android:layout_weight="1"
                android:id="@+id/mbtSave"
                android:layout_width="0dp"
                android:text="@string/save"
                android:layout_height="40dp"
                android:textColor="@color/white_or_black"
                android:backgroundTint="@color/black_or_white"/>

            <com.google.android.material.button.MaterialButton
                app:cornerRadius="5dp"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:id="@+id/mbtDelete"
                android:layout_height="40dp"
                android:text="@string/delete"
                android:layout_marginStart="15dp"
                android:textColor="@color/white_or_black"
                android:backgroundTint="@color/black_or_white" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/pb"
            android:layout_height="40dp"
            android:layout_width="match_parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:indeterminateTint="@color/black_or_white" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>